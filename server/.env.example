PORT=5000
# MongoDB Atlas(있으면 우선). 없으면 localhost:27017/shopingmall 자동 사용
# mongodb_atlas_url=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/dbname
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d

# 포트원 — REST API 키·시크릿·고객사 식별코드는 동일 콘솔 가맹점 값으로 맞출 것
# PORTONE_IMP_KEY=
# PORTONE_IMP_SECRET=
# PORTONE_IMP_CODE=imp00000000
# 로컬만 검증 생략(true이면 키 없이 completed 허용·운영 금지)
# PORTONE_SKIP_PAYMENT_VERIFY=false
