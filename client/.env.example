VITE_PORT=5173
VITE_API_URL=http://localhost:5000

# 포트원(구 아임포트) 결제 — pg 오류 시 콘솔에 맞는 MID/채널로 조정
# VITE_PORTONE_IMP_CODE=imp00000000
# KG이니시스(html5) 테스트 기본은 INIpayTest, 운영 MID로 교체
# VITE_PORTONE_INICIS_MID=INIpayTest
# 콘솔 채널키를 쓰면 request_pay에 channelKey가 들어가고 pg는 생략됨(채널 하나로 통일할 때)
# VITE_PORTONE_CHANNEL_KEY=
# 카카오/네이버가 CID를 요구하면 전체 pg 문자열로 지정 (예: kakaopay.xxxxx)
# VITE_PORTONE_KAKAO_PG=
# VITE_PORTONE_NAVER_PG=

# Cloudinary Upload Widget (https://cloudinary.com)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
